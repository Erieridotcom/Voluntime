{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "1. Instalar dependencias",
      "type": "shell",
      "command": "pip3 install -r backend/requirements.txt && pnpm install",
      "windows": {
        "command": "python -m pip install -r backend/requirements.txt ; pnpm install"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Backend",
      "type": "shell",
      "command": "python3 -m backend.main",
      "windows": {
        "command": "python -m backend.main"
      },
      "group": "build",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend",
      "type": "shell",
      "command": "pnpm --filter @workspace/voluntariado run dev",
      "group": "build",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Iniciar VoluntaRed",
      "dependsOn": ["Backend", "Frontend"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always"
      },
      "problemMatcher": []
    }
  ]
}
